<HomeView>:

    MDLabel:
        text: "Home View here."
        halign: "center"
        theme_text_color: "Primary"

    MDAnchorLayout:

        anchor_x: "center"
        anchor_y: "center"
        height: root.height
        width: root.width

        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(32)
            size_hint: .7, None
            height: self.minimum_height

            ButtonLink:
                button_text: "               Scan and Connect Devices               "
                target_page: "Bluetooth Manager"