<HomeView>:

    MDAnchorLayout:
        anchor_x: "center"
        anchor_y: "center"
        height: root.height
        width: root.width

        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(32)
            size_hint: .7, None
            height: self.minimum_height

            ButtonLink:
                button_text: "               Scan and Connect Devices               "
                id: bluetooth_scanning_link

            ButtonLink:
                button_text: "                                    Chats                                    "
                id: chat_list_link

            ButtonLink:
                button_text: "                             Group Chats                             "
                id: group_chat_list_link
